# =============================================================================
# e2eAtScale — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials — never commit
# -----------------------------------------------------------------------------
.env
*.pem
*.key

# -----------------------------------------------------------------------------
# Local test results
# -----------------------------------------------------------------------------
local_results/
results-*.json
summary-*.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest / coverage artifacts
.coverage
coverage.xml
htmlcov/
junit*.xml
report.json

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
test-results/
playwright-report/
/playwright/.cache/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Don't ignore Dockerfile itself — only local build artifacts
*.tar

# -----------------------------------------------------------------------------
# AWS / boto3
# -----------------------------------------------------------------------------
# Local AWS credential overrides (use Jenkins credentials store in CI)
.aws/

# CDK output (if added later)
cdk.out/

# -----------------------------------------------------------------------------
# Node (pptxgenjs, docx build scripts — not part of the repo itself)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
package-lock.json

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# JetBrains / VS Code / editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
